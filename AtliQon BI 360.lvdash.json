    {
      "name": "top_10_products",
      "displayName": "Top 10 Products by Revenue",
      "queryLines": [
        "SELECT\n",
        "  product,\n",
        "  SUM(total_amount_inr) as total_revenue\n",
        "FROM\n",
        "  fmcg.gold.vw_fact_orders_enriched\n",
        "GROUP BY\n",
        "  product\n",
        "ORDER BY\n",
        "  total_revenue DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "top_10_variants",
      "displayName": "Top 10 Variants by Revenue",
      "queryLines": [
        "SELECT\n",
        "  variant,\n",
        "  SUM(total_amount_inr) as total_revenue\n",
        "FROM\n",
        "  fmcg.gold.vw_fact_orders_enriched\n",
        "GROUP BY\n",
        "  variant\n",
        "ORDER BY\n",
        "  total_revenue DESC\n",
        "LIMIT 10"
      ]
    }
  ],
